# ── Runtime required (set these in Vercel) ────────────────────────────────────
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=
LANGSMITH_API_KEY=

# ── Runtime optional (Vercel uses these defaults if not set) ──────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=friday-doc-assistant
LANGSMITH_TRACING_BACKGROUND=false

# ── Local scripts only (not needed on Vercel) ─────────────────────────────────
DOCS_BASE_URL=
EMBED_BATCH_SIZE=100
EMBED_CONCURRENCY=2
